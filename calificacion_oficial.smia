# Regresar a root
login -user=root -pass=123 -id=301A

# ----------------- 14. MKFILE -----------------
mkfile -path=/home/archivos/user/docs/Tarea.txt -size=75
mkfile -path=/home/archivos/user/docs/Tarea2.txt -size=768

# Crear archivo en sistema real para -cont
