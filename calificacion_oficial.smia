# ----------------- 1. MKDISK -----------------
# 50M A
mkdisk -size=50 -unit=M -fit=FF -path=/home/jona/Calificacion_MIA/Discos/Disco1.mia

# 50M B
mkdisk -unit=K -size=51200 -fit=BF -path=/home/jona/Calificacion_MIA/Discos/Disco2.mia

# 13M C
mkdisk -size=13 -path=/home/jona/Calificacion_MIA/Discos/Disco3.mia

# ----------------- 2. RMDISK -----------------
# ERROR: Disco no existe
rmdisk -path=/home/jona/Calificacion_MIA/Discos/DiscoN.mia

# ----------------- 3. FDISK -----------------
# DISCO 1 - Primarias
fdisk -type=P -unit=B -name=Part11 -size=10485760 -path=/home/jona/Calificacion_MIA/Discos/Disco1.mia -fit=BF
fdisk -type=P -unit=K -name=Part12 -size=10240 -path=/home/jona/Calificacion_MIA/Discos/Disco1.mia -fit=BF
fdisk -type=P -unit=M -name=Part13 -size=10 -path=/home/jona/Calificacion_MIA/Discos/Disco1.mia -fit=BF
fdisk -type=P -unit=B -name=Part14 -size=10485760 -path=/home/jona/Calificacion_MIA/Discos/Disco1.mia -fit=BF

# ERROR: Límite de particiones primarias
fdisk -type=P -unit=B -name=PartErr -size=10485760 -path=/home/jona/Calificacion_MIA/Discos/Disco1.mia -fit=BF

# DISCO 3
fdisk -type=P -unit=M -name=Part31 -size=4 -path=/home/jona/Calificacion_MIA/Discos/Disco3.mia
fdisk -type=P -unit=M -name=Part32 -size=4 -path=/home/jona/Calificacion_MIA/Discos/Disco3.mia
fdisk -type=P -unit=M -name=Part33 -size=1 -path=/home/jona/Calificacion_MIA/Discos/Disco3.mia

# ----------------- 4. MOUNT -----------------
# DISCO 1 → IDs: 301A, 302A, 303A, 304A
mount -path=/home/jona/Calificacion_MIA/Discos/Disco1.mia -name=Part11
mount -path=/home/jona/Calificacion_MIA/Discos/Disco1.mia -name=Part12

# ERROR: Partición ya montada
mount -path=/home/jona/Calificacion_MIA/Discos/Disco1.mia -name=Part11

# DISCO 3 → IDs: 301B, 302B (cambia letra por ser otro disco)
mount -path=/home/jona/Calificacion_MIA/Discos/Disco3.mia -name=Part31
mount -path=/home/jona/Calificacion_MIA/Discos/Disco3.mia -name=Part32

# ----------------- MOUNTED -----------------
mounted

# ----------------- REPORTES PARTE 1 -----------------
# ERROR: ID no encontrado
rep -id=A301 -path=/home/jona/Calificacion_MIA/Reportes/p1_rE.jpg -name=mbr

# Reporte DISK
rep -id=301A -path=/home/jona/Calificacion_MIA/Reportes/p1_r1_disk.jpg -name=disk

# Reporte MBR
rep -id=301A -path=/home/jona/Calificacion_MIA/Reportes/p1_r2_mbr.jpg -name=mbr

# DISCO 3
rep -id=301B -path=/home/jona/Calificacion_MIA/Reportes/p1_r3_disk.jpg -name=disk
rep -id=302B -path=/home/jona/Calificacion_MIA/Reportes/p1_r4_disk.jpg -name=mbr

# ----------------- 5. MKFS -----------------
mkfs -type=full -id=301A

# ----------------- 7. LOGIN -----------------
login -user=root -pass=123 -id=301A

# ERROR: Sesión ya iniciada
login -user=root -pass=123 -id=301A

# ----------------- 9. MKGRP -----------------
mkgrp -name=usuarios
mkgrp -name=adm
mkgrp -name=mail
mkgrp -name=news
mkgrp -name=sys

# ERROR: Grupo ya existe
mkgrp -name=sys

# ----------------- 6. CAT -----------------
cat -file1=/users.txt

# ----------------- 10. RMGRP -----------------
rmgrp -name=mail

# ----------------- 6. CAT -----------------
cat -file1=/users.txt

# ----------------- 11. MKUSR -----------------
mkusr -user=usuario1 -pass=password -grp=root
mkusr -user=user1 -pass=abc -grp=usuarios
mkusr -user=user2 -pass=abc -grp=usuarios

# ERROR: Usuario ya existe
mkusr -user=user2 -pass=abc -grp=usuarios

# ERROR: Grupo no existe
mkusr -user=user3 -pass=abc -grp=system

# ----------------- 6. CAT -----------------
cat -file1=/users.txt

# ----------------- 13. CHGRP -----------------
chgrp -user=user2 -grp=adm

# ----------------- 6. CAT -----------------
cat -file1=/users.txt

# ----------------- 12. RMUSR -----------------
rmusr -user=user2

# ----------------- 6. CAT -----------------
cat -file1=/users.txt

# ----------------- 15. MKDIR -----------------
mkdir -path=/bin

# ERROR: No existen carpetas padres
mkdir -path=/home/archivos/archivos24

mkdir -p -path=/home/archivos/user/docs/usac
mkdir -p -path=/home/archivos/carpeta1/carpeta2/carpeta3/carpeta4/carpeta5

# ----------------- 8. LOGOUT -----------------
logout

# ERROR: No hay sesión
logout

# ----------------- 7. LOGIN -----------------
login -user=user1 -pass=abc -id=301A
