rep -id=301A -path=/home/jona/Calificacion_MIA/Reportes/p4_r5_sb.jpg -name=sb
rep -id=301A -path=/home/jona/Calificacion_MIA/Reportes/p4_r6_file.jpg -path_file_ls=/home/archivos/user/docs/Tarea2.txt -name=file
rep -id=301A -path=/home/jona/Calificacion_MIA/Reportes/p4_r7_ls.jpg -path_file_ls=/home/archivos/user/docs -name=ls
